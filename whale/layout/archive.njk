<%- partial('partials/ticker') %>

<section class="max-w-[1400px] mx-auto px-6 py-16">
  <div class="text-mute font-mono text-xs mb-2">~/archives</div>
  <h2 class="cn text-3xl font-semibold tracking-tight mb-10"><%- __('archives') %></h2>

  <%
    // 按年月分组
    const archives = {};
    site.posts.sort('date', -1).each(function(post) {
      const year = post.date.format('YYYY');
      const month = post.date.format('MM');
      if (!archives[year]) archives[year] = {};
      if (!archives[year][month]) archives[year][month] = [];
      archives[year][month].push(post);
    });

    Object.keys(archives).forEach(function(year) {
  %>
  <div class="mb-12">
    <h3 class="font-mono text-lg font-medium mb-6 text-accent"><%= year %> <span class="text-dim text-sm">/</span> <%- __('月份') %></h3>
    <div class="space-y-4">
      <% archives[year].forEach(function(monthPosts, month) { %>
      <div class="ml-4 border-l-2" style="border-color: var(--border);">
        <div class="text-mute text-xs font-mono mb-2"><%= parseInt(month) %><%- __('月') %></div>
        <% monthPosts.each(function(post) { %>
        <article class="row">
          <span class="date"><%= post.date.format('DD') %></span>
          <div>
            <h3 class="cn"><a class="ulink" href="<%- url_for(post.path) %>"><%= post.title %></a></h3>
            <p class="cn text-dim text-sm mt-1"><%= (post.description || '').substring(0, 60) %></p>
          </div>
          <div class="meta hide-sm">
            <% if (post.tags && post.tags.length) { %>
            <% post.tags.forEach(function(tag) { %>
              <span class="tag"><%= tag.name %></span>
            <% }); %>
            <% } %>
          </div>
        </article>
        <% }); %>
      </div>
      <% }); %>
    </div>
  </div>
  <% }); %>
</section>

<%- partial('partials/subscribe') %>

<!-- ===================== 数据条 ===================== -->
<section class="max-w-[1400px] mx-auto px-6 py-14 md:py-16">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-px rounded-2xl overflow-hidden" style="background: var(--border); border-color: var(--border);">
    <% (theme.theme.stats || []).forEach(function(stat) { %>
    <div class="p-7 md:p-8" style="background: var(--bg-elev);">
      <div class="text-mute text-xs font-mono mb-3"><%= stat.label %></div>
      <div class="text-3xl md:text-[34px] font-semibold font-mono"><%= stat.value %></div>
      <div class="text-dim text-xs mt-1.5"><%= stat.desc %></div>
    </div>
    <% }); %>
  </div>
</section>

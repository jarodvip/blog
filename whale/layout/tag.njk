<%- partial('partials/ticker') %>

<section class="max-w-[1400px] mx-auto px-6 py-16">
  <div class="text-mute font-mono text-xs mb-2">~/tags</div>
  <h2 class="cn text-3xl font-semibold tracking-tight mb-10"><%- __('tags') %></h2>

  <%
    const tags = site.tags.sort('length', -1);
    tags.each(function(tag) {
  %>
  <a class="tag mr-3 mb-3 inline-block" href="<%- url_for(tag.path) %>">
    <%= tag.name %> <span class="text-mute">(<%= tag.length %>)</span>
  </a>
  <% }); %>
</section>

<%- partial('partials/subscribe') %>
